# Copy to .env — only set what you need. Defaults live in app/core/config.py.

# Hugging Face (optional for public models; avoids rate limits)
HF_TOKEN=

# Frontend origin(s) for CORS — JSON list or comma-separated
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Railway / production (set in Railway Variables, not usually in this file):
# DATABASE_URL=sqlite:////app/storage/ai_exterior_studio.db
# CORS_ORIGINS=https://your-frontend.up.railway.app
# AUTO_DOWNLOAD_MODELS=true
